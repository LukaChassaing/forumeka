# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Database (Sprint 1) ---
DATABASE_URL=postgresql://user:password@host:5432/forumeka

# --- Auth (Sprint 2) ---
AUTH_SECRET=
AUTH_URL=http://localhost:3000
RESEND_API_KEY=re_...
RESEND_FROM=noreply@forumeka.fr

# --- Stripe (Monétisation V1) ---
# Clé secrète (Dashboard > Développeurs > Clés API)
STRIPE_SECRET_KEY=sk_test_...
# Secret de signature du endpoint webhook (Dashboard > Développeurs > Webhooks, ou `stripe listen`)
STRIPE_WEBHOOK_SECRET=whsec_...
# IDs des Prices récurrents créés dans le Dashboard (4,99€/mois et 39,99€/an)
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# --- Extractor ---
EXTRACTOR_USER_AGENT="Forumeka/0.1 (+https://forumeka.fr/bot)"
EXTRACTOR_RATE_LIMIT_MS=2000
